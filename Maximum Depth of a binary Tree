/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public int maxDepth(TreeNode root) {
        int count= 0;
       List<List<Integer>>  ans = new ArrayList<>();
     if( root == null ) 
     return 0;
     Queue<TreeNode> qt = new LinkedList<>();
        qt.offer( root);
        while( !qt.isEmpty()){ 
             int size  = qt.size();
             List<Integer> level = new ArrayList<>();
              
              for( int i =0;i<size;i++){
                TreeNode ek  = qt.poll();
                  level.add(ek.val);
                  if( ek.left != null )
                    qt.add( ek.left);

                 if( ek.right !=null){
                    qt.add(ek.right);
                 }
                
              }
              count++;
               ans.add( level);
             
        }
        return count ;
    }
}
