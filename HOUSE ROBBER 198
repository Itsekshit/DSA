class Solution {
    public int rob(int[] nums) {
      return ekshit( 0 , nums);
    
    }
    int ekshit( int i , int nums[]){
          int n = nums.length;
            if( i >=n)
                return 0;
int rob = nums[i] + ekshit(i + 2, nums);

        int skip = ekshit(i + 1, nums);

      
        return Math.max(rob, skip);
    }
}
